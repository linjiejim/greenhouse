{
  "name": "greenhouse",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"pnpm web:dev\" \"pnpm api\"",
    "api": "tsx apps/api/src/index.ts",
    "web:build": "pnpm --filter @greenhouse/web build",
    "web:dev": "pnpm --filter @greenhouse/web dev",
    "mobile:install": "cd apps/mobile && pnpm install --ignore-workspace",
    "mobile": "cd apps/mobile && npx expo start --dev-client",
    "mobile:web": "cd apps/mobile && npx expo start --web --port 8081",
    "mobile:prebuild": "cd apps/mobile && npx expo prebuild --clean",
    "mobile:ios": "cd apps/mobile && npx expo run:ios",
    "mobile:android": "cd apps/mobile && npx expo run:android",
    "cli": "tsx apps/api/src/cli/index.ts",
    "help": "tsx apps/api/src/cli/index.ts --help",
    "chat": "tsx apps/api/src/cli/index.ts chat",
    "admin:create": "tsx apps/api/src/cli/index.ts users create",
    "seed": "tsx apps/api/src/cli/index.ts seed",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:ci": "bash scripts/e2e-ci.sh",
    "test:e2e:ui": "playwright test",
    "test:e2e:ui:report": "playwright show-report",
    "typecheck": "tsc --noEmit",
    "lint": "eslint apps/ packages/ && prettier --check apps/ packages/",
    "lint:fix": "eslint --fix apps/ packages/ && prettier --write apps/ packages/",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "packages/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "apps/**/*.{json,yaml,yml,css,html}": [
      "prettier --write"
    ],
    "packages/**/*.{json,yaml,yml,css,html}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.0.0",
    "@types/web-bluetooth": "^0.0.21",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "^3.1.0",
    "yaml": "^2.7.1"
  }
}
