{
  "name": "greenhouse",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"pnpm web:dev\" \"API_PORT=${API_PORT:-3101} pnpm api\"",
    "api": "tsx apps/api/src/index.ts",
    "chat": "tsx apps/api/src/cli/chat.ts",
    "web:build": "pnpm --filter @greenhouse/web build",
    "web:dev": "pnpm --filter @greenhouse/web dev",
    "admin:create": "tsx apps/api/src/cli/admin-create.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint apps/ packages/ && prettier --check apps/ packages/",
    "lint:fix": "eslint --fix apps/ packages/ && prettier --write apps/ packages/",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "packages/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "apps/**/*.{json,yaml,yml,css,html}": [
      "prettier --write"
    ],
    "packages/**/*.{json,yaml,yml,css,html}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@types/web-bluetooth": "^0.0.21",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "^3.1.0",
    "yaml": "^2.7.1"
  }
}
