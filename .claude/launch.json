{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "greenhouse",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev"],
      "port": 4400
    },
    {
      "name": "greenhouse-verify",
      "runtimeExecutable": "sh",
      "runtimeArgs": [
        "-c",
        "STORAGE_DRIVER=local EXPORT_PRESIGN_THRESHOLD_BYTES=0 API_PORT=4411 WEB_PORT=4410 pnpm dev"
      ],
      "port": 4410
    },
    {
      "name": "mobile-web",
      "runtimeExecutable": "sh",
      "runtimeArgs": [
        "-c",
        "cd apps/mobile && npx expo start --web --port 8095"
      ],
      "port": 8095
    },
    {
      "name": "docs-landing",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "4599", "--directory", "docs"],
      "port": 4599
    }
  ]
}
