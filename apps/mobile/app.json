{
  "expo": {
    "name": "Greenhouse",
    "slug": "greenhouse-mobile",
    "scheme": "greenhouse",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.greenhouse.mobile",
      "appleTeamId": "3SKAS5BNK9",
      "entitlements": {
        "com.apple.security.application-groups": ["group.app.greenhouse.mobile"]
      }
    },
    "android": {
      "package": "app.greenhouse.mobile"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "@bacons/apple-targets",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-router",
      "expo-secure-store",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
