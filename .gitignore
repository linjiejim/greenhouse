# Environment (never commit real env files; only the *.example template)
.env
.env.*
!.env.example

# Dependencies
node_modules/

# Playwright (browser e2e) — generated artifacts + saved auth state
/playwright-report/
/test-results/
/blob-report/
tests/e2e-ui/.auth/

# Build output
dist/

# Packaged browser extension (built by `pnpm -F @greenhouse/browser package`)
apps/browser/*.zip

# CLI build artifacts (CLI runs via tsx on .ts sources directly)
apps/cli/src/*.js

# OS
.DS_Store

# IDE
.idea/
.vscode/
*.swp
*.swo

# Built frontend (Vite emits the hashed bundle here; nothing is committed)
public/*

dist-web/

# Desktop (Electron packaged installers; dist/ is already ignored above)
apps/desktop/release/

# Database files (runtime, not source)
data/db/

# Crawled blog posts (regeneratable)
data/raw/blog/

# Downloaded PDF manuals (large, regeneratable)
data/raw/manuals/

# User uploads (runtime data)
data/uploads/

# Legacy apps/data location
apps/data/

# Turbo
.turbo/
.gstack/

# Claude Code — machine-local settings (permissions, absolute paths). launch.json
# stays tracked (no secrets); only the *.local.json files are per-machine.
.claude/settings.local.json
.claude/*.local.json
.claude/skills/ppt-master

# Local-only docs (credentials etc.)
docs/local/

# Experimental specs and sketches
docs/specs/
docs/sketches/