# ════════════════════════════════════════════════════════════════
#  Greenhouse — environment configuration
#  Copy to .env and fill in. For docker-compose, the bundled stack
#  auto-generates the required secrets on first run (see docker-compose.yml).
# ════════════════════════════════════════════════════════════════

# ─────────────── REQUIRED ───────────────

# PostgreSQL connection.
DATABASE_URL=postgresql://greenhouse:greenhouse@localhost:5432/greenhouse

# Auth (fail-closed — the server REFUSES TO START without these).
# ACCESS_PASSWORD gates all internal routes; an unset value would disable auth
# and grant every request super-user access, so it is mandatory everywhere.
ACCESS_PASSWORD=change-me
# Independent random signing key (NOT derived from ACCESS_PASSWORD). No fallback.
# Generate: openssl rand -hex 32
TOKEN_SIGNING_KEY=

# Encryption key for stored secrets (team LLM gateway upstream keys, email
# account credentials). AES-256-GCM. Generate: openssl rand -hex 32
PROVIDER_TOKEN_ENCRYPTION_KEY=

# LLM — the kernel speaks ONE protocol: OpenAI-compatible. Point these at any
# OpenAI-compatible endpoint (OpenAI, DeepSeek's OpenAI endpoint, a local Ollama
# /v1, a gateway, …). All logical model ids (default/flash/pro/title) resolve to LLM_MODEL.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-api-key
LLM_MODEL=gpt-4o-mini

# ─────────────── OPTIONAL ───────────────

# Server ports — override to avoid conflicts with other local services. Both are
# read from this .env file (a shell env var of the same name still takes
# precedence, e.g. `API_PORT=4001 pnpm dev`).
#   API_PORT: port the API listens on (default 3000). The web dev proxy targets it.
#   WEB_PORT: Vite dev-server port (default 3100). Dev-only — in production the API
#     serves the built SPA on API_PORT, so there is no separate web port.
# API_PORT=3000
# WEB_PORT=3100
# PRODUCT_NAME=Greenhouse
# Comma-separated browser origins allowed by CORS (empty = same-origin only).
# CORS_ALLOWED_ORIGINS=https://greenhouse.example.com
# Extra CSP connect-src origins (space/comma-separated) for a fork's external
# calls, e.g. OAuth token endpoints. Empty = 'self' only.
# CSP_CONNECT_SRC=https://oauth2.googleapis.com https://graph.microsoft.com
# Outbound proxy for external API calls (search, LLM) if needed.
# HTTPS_PROXY=
# Log verbosity: debug | info | warn | error | silent (default: info).
# LOG_LEVEL=info

# A heavier model for the `pro` logical id (defaults to LLM_MODEL).
# LLM_MODEL_PRO=

# Light model for auto-title generation (defaults to LLM_MODEL). Use a NON-thinking
# model: a reasoning model spends its output budget on thinking tokens and returns
# empty content, producing blank ("Untitled") titles. e.g. deepseek-chat.
# LLM_MODEL_TITLE=

# Vision (analyze_image) — OpenAI-compatible multimodal endpoint.
# Falls back to LLM_* if unset; errors clearly if neither is configured.
# IMAGE_API_KEY=
# IMAGE_API_BASE_URL=https://api.openai.com/v1
# VISION_MODEL=gpt-4o-mini

# Image generation (generate_image) — OpenAI-compatible image API (both required to enable).
# GPT_IMAGE_API_KEY=
# GPT_IMAGE_BASE_URL=https://api.openai.com/v1
# Optional secondary provider used when the primary fails (generation only).
# GLM_IMAGE_API_KEY=
# GLM_IMAGE_BASE_URL=

# External web search (external_search tool) — at least one provider to enable.
# TAVILY_API_KEY=
# FIRECRAWL_API_KEY=
# BRAVE_SEARCH_API_KEY=

# Uploads (chat images / generated images / exported files) are stored on local
# disk under data/uploads — fine for single-instance deploys. No config needed.
#
# STORAGE_DRIVER=local turns on a disk-backed OBJECT-STORAGE driver that also issues
# presigned (HMAC-signed, expiring) download URLs — the same code path a real
# S3/COS driver uses, but with no external service. Use it to verify the object-
# storage / presigned flow locally; leave it unset for the plain local-disk default.
# STORAGE_DRIVER=local
# Secret used to sign presigned URLs (falls back to TOKEN_SIGNING_KEY, then an
# insecure dev default). Set it if you enable STORAGE_DRIVER=local outside dev.
# STORAGE_PRESIGN_SECRET=
